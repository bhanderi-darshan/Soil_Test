
#include <WiFi.h>
#include <HTTPClient.h>
#include <WiFiManager.h>
#include <ModbusMaster.h>

#define RXD2 3
#define TXD2 4

HardwareSerial RS485Serial(1);
ModbusMaster node;

WiFiManager wm;

// change only this line
String serverName = "http:// 10.239.107.1/Product/receive.php";

void setup()
{
  Serial.begin(115200);

  RS485Serial.begin(4800, SERIAL_8N1, RXD2, TXD2);
  node.begin(1, RS485Serial);

  Serial.println("Starting WiFi Manager...");

  bool res;

  res = wm.autoConnect("SoilSensor_Setup");

  if(!res)
  {
    Serial.println("WiFi Failed");
    ESP.restart();
  }

  Serial.println("WiFi Connected!");
}

void loop()
{
  uint8_t result;

  result = node.readHoldingRegisters(0x0000, 3);

  if(result == node.ku8MBSuccess)
  {
    float temperature = node.getResponseBuffer(0) / 10.0;
    float moisture = node.getResponseBuffer(1) / 10.0;
    int ec_value = node.getResponseBuffer(2);

    Serial.println("Sending Data To Server...");

    if(WiFi.status() == WL_CONNECTED)
    {
      HTTPClient http;

      String url = serverName +
                   "?device=ESP32_1" +
                   "&moisture=" + String(moisture) +
                   "&ec=" + String(ec_value) +
                   "&temp=" + String(temperature);

      http.begin(url);

      int httpResponseCode = http.GET();

      if(httpResponseCode > 0)
      {
        String response = http.getString();
        Serial.println(response);
      }
      else
      {
        Serial.print("HTTP Error: ");
        Serial.println(httpResponseCode);
      }

      http.end();
    }
  }
  else
  {
    Serial.println("Sensor read failed");
  }

  delay(5000);
}
